import pandas as pd
import matplotlib.pyplot as plt
from pathlib import Path

data_path = Path('data') / 'prompt_results.csv'
df = pd.read_csv(data_path)

df.columns = [c.strip().lower() for c in df.columns]

rename_map = {}
if 'model_a' not in df.columns and 'assistant_1_model' in df.columns:
    rename_map['assistant_1_model'] = 'model_a'
if 'model_b' not in df.columns and 'assistant_2_model' in df.columns:
    rename_map['assistant_2_model'] = 'model_b'
if 'winner_vendor' not in df.columns and 'vendor' in df.columns:
    rename_map['vendor'] = 'winner_vendor'
df = df.rename(columns=rename_map)

def get_vendor(model_name):
    model_name = str(model_name).lower()
    if 'gpt' in model_name:
        return 'OpenAI'
    if 'gemini' in model_name:
        return 'Google'
    return 'Other'

if 'winner_vendor' not in df.columns:
    df['winner_vendor'] = df['winner'].apply(get_vendor)

df.head()
